# --- Site ---
NEXT_PUBLIC_SITE_URL=https://smrc33.fr

# --- Authentification admin ---
# Email de connexion à l'espace /admin
ADMIN_EMAIL=admin@smrc33.fr
# Hash bcrypt du mot de passe admin (générer avec: node scripts/hash-password.mjs "monMotDePasse")
ADMIN_PASSWORD_HASH=
# Secret utilisé pour signer les sessions (chaîne aléatoire longue)
AUTH_SECRET=change-me-with-a-long-random-string

# --- GitHub (persistance du contenu via commits) ---
GITHUB_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=
GITHUB_BRANCH=main

# --- Stockage images (optionnel, Vercel Blob) ---
BLOB_READ_WRITE_TOKEN=
